    "def cluster_purity(y_true, cluster_labels):\n",
    "    \"\"\"\n",
    "    根据真实标签和聚类分配计算聚类纯度。\n",
    "\n",
    "    参数:\n",
    "        y_true: 真实类别标签的数组\n",
    "        cluster_labels: 聚类算法分配的簇标签数组\n",
    "\n",
    "    返回:\n",
    "        purity: 聚类纯度值，范围 [0, 1]，值越大表示聚类质量越好\n",
    "\n",
    "    说明:\n",
    "        纯度（Purity）是一种聚类评估指标，计算方法如下：\n",
    "        1. 对于每个簇，找出其中数量最多的真实类别\n",
    "        2. 将所有簇中该最多类别的样本数量相加\n",
    "        3. 除以样本总数得到纯度\n",
    "        纯度为 1 表示完美聚类，为 1/k（k为类别数）表示随机聚类。\n",
    "    \"\"\"\n",
    "    y_true = np.asarray(y_true)\n",
    "    cluster_labels = np.asarray(cluster_labels)\n",
    "    assert y_true.shape[0] == cluster_labels.shape[0]\n",
    "\n",
    "    total = y_true.shape[0]\n",
    "    purity_sum = 0\n",
    "\n",
    "    # 遍历每个聚类簇\n",
    "    for cluster in np.unique(cluster_labels):\n",
    "        # 获取当前簇中的所有样本的真实标签\n",
    "        mask = cluster_labels == cluster\n",
    "        true_labels_cluster = y_true[mask]\n",
    "        if true_labels_cluster.size == 0:\n",
    "            continue\n",
    "        # 计算当前簇中每个类别的样本数量\n",
    "        counts = np.bincount(true_labels_cluster)\n",
    "        # 选择数量最多的类别\n",
    "        majority_label_count = counts.max()\n",
    "        purity_sum += majority_label_count\n",
    "\n",
    "    return purity_sum / total"
   ],
