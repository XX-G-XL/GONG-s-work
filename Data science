    "def compare_similarity_within_class_vs_random(train_X, train_Y, label_for_subset):\n",
    "    \"\"\"\n",
    "    创建两个子集并使用直方图比较子集内部的相似度。\n",
    "\n",
    "    参数:\n",
    "        train_X: 训练集特征矩阵\n",
    "        train_Y: 训练集标签\n",
    "        label_for_subset: 用于创建第一个子集的类别标签\n",
    "\n",
    "    说明:\n",
    "        该函数创建两个子集：\n",
    "        1. subset1: 仅包含指定类别的样本\n",
    "        2. subset2: 随机选择的样本（可能来自任意类别）\n",
    "        通过比较这两个子集内部样本间的距离分布，分析同类样本的相似度。\n",
    "    \"\"\"\n",
    "    print(\"=== Question 1(d): Similarity within class vs random images ===\")\n",
    "    print(f\"Reference class for subset 1: {label_for_subset}\")\n",
    "\n",
    "    # 获取指定类别的所有样本\n",
    "    mask_label = train_Y == label_for_subset\n",
    "    X_label = train_X[mask_label]\n",
    "\n",
    "    # 设置子集大小，最多选择 200 个样本\n",
    "    subset_size = min(200, X_label.shape[0])\n",
    "    rng = np.random.RandomState(RANDOM_STATE)\n",
    "\n",
    "    # 子集 1: 从指定类别中随机选择样本\n",
    "    indices_label = rng.choice(X_label.shape[0], size=subset_size, replace=False)\n",
    "    subset1 = X_label[indices_label]\n",
    "\n",
    "    # 子集 2: 从整个训练集中随机选择样本\n",
    "    indices_random = rng.choice(train_X.shape[0], size=subset_size, replace=False)\n",
    "    subset2 = train_X[indices_random]\n",
    "\n",
    "    print(f\"Subset1 (class {label_for_subset}) size: {subset1.shape[0]}\")\n",
    "    print(f\"Subset2 (random) size: {subset2.shape[0]}\")\n",
    "\n",
    "    # 计算两个子集内部的成对距离\n",
    "    distances_subset1 = pairwise_distances_euclidean(subset1)\n",
    "    distances_subset2 = pairwise_distances_euclidean(subset2)\n",
    "\n",
    "    # 绘制两个子集的距离分布直方图\n",
    "    plt.figure(figsize=(8, 4))\n",
    "    # 使用相同的 bins 范围确保直方图可比较\n",
