    "def tune_random_forest_classifier(X, y, n_estimators_list, max_depth_list, n_splits=5):\n",
    "    \"\"\"\n",
    "    使用 K 折交叉验证手动调整随机森林的超参数。\n",
    "\n",
    "    参数:\n",
    "        X: 特征矩阵\n",
    "        y: 标签向量\n",
    "        n_estimators_list: 要测试的树的数量列表\n",
    "        max_depth_list: 要测试的树的最大深度列表（None 表示无限制）\n",
    "        n_splits: K 折交叉验证的折数，默认为 5\n",
    "\n",
    "    返回:\n",
    "        best_params: 最佳参数组合的元组 (n_estimators, max_depth)\n",
    "        best_score: 最佳参数对应的平均交叉验证准确率\n",
    "\n",
    "    说明:\n",
    "        随机森林是集成学习方法，通过组合多个决策树来提高预测性能。\n",
    "        n_estimators 控制树的数量，max_depth 控制每棵树的深度。\n",
    "        较多的树和较深的深度可能提高性能，但也会增加计算成本和过拟合风险。\n",
    "    \"\"\"\n",
    "    best_params = None\n",
    "    best_score = -np.inf\n",
    "    kf = KFold(n_splits=n_splits, shuffle=True, random_state=RANDOM_STATE)\n",
    "\n",
    "    # 网格搜索：遍历所有参数组合\n",
    "    for n_estimators in n_estimators_list:\n",
    "        for max_depth in max_depth_list:\n",
    "            fold_scores = []\n",
    "            for train_idx, val_idx in kf.split(X):\n",
    "                X_tr, X_val = X[train_idx], X[val_idx]\n",
    "                y_tr, y_val = y[train_idx], y[val_idx]\n",
    "\n",
    "                # 随机森林不需要特征标准化，因为决策树基于特征分割\n",
    "                clf = RandomForestClassifier(\n",
    "                    n_estimators=n_estimators,\n",
    "                    max_depth=max_depth,\n",
    "                    random_state=RANDOM_STATE,\n",
    "                    n_jobs=-1,  # 使用所有可用的 CPU 核心\n",
    "                )\n",
    "                clf.fit(X_tr, y_tr)\n",
    "                y_val_pred = clf.predict(X_val)\n",
    "                fold_scores.append(accuracy_score(y_val, y_val_pred))\n",
    "\n",
    "            mean_score = np.mean(fold_scores)\n",
    "            print(\n",
    "                f\"Random forest: n_estimators={n_estimators}, \"\n",
    "                f\"max_depth={max_depth} mean CV accuracy={mean_score:.4f}\"\n",
    "            )\n",
    "\n",
    "            if mean_score > best_score:\n",
    "                best_score = mean_score\n",
    "                best_params = (n_estimators, max_depth)\n",
    "\n",
    "    return best_params, best_score"
