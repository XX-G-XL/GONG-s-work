    "    随机选择四个类别并绘制它们的均值和中位数图像。\n",
    "\n",
    "    参数:\n",
    "        train_X: 训练集特征矩阵\n",
    "        train_Y: 训练集标签\n",
    "        image_side: 图像边长\n",
    "        classes: 所有类别的数组\n",
    "\n",
    "    返回:\n",
    "        selected_classes: 被选中的四个类别\n",
    "    \"\"\"\n",
    "    print(\"=== Question 1(b): Mean and median images ===\")\n",
    "    # 使用固定随机种子确保结果可重复\n",
    "    rng = np.random.RandomState(RANDOM_STATE)\n",
    "    # 从所有类别中随机选择四个类别\n",
    "    selected_classes = rng.choice(classes, size=4, replace=False)\n",
    "    print(\"Selected classes for mean/median images:\", selected_classes)\n",
    "\n",
    "    # 创建 2x4 的子图网格：第一行显示均值图像，第二行显示中位数图像\n",
    "    fig, axes = plt.subplots(2, 4, figsize=(10, 5))\n",
    "\n",
    "    for idx, c in enumerate(selected_classes):\n",
