    "def tune_logistic_regression(X, y, C_values, n_splits=5):\n",
    "    \"\"\"\n",
    "    使用 K 折交叉验证手动调整逻辑回归的超参数。\n",
    "\n",
    "    参数:\n",
    "        X: 特征矩阵\n",
    "        y: 标签向量\n",
    "        C_values: 要测试的正则化参数 C 的列表（C 值越小，正则化越强）\n",
    "        n_splits: K 折交叉验证的折数，默认为 5\n",
    "\n",
    "    返回:\n",
    "        best_C: 最佳的 C 参数值\n",
    "        best_score: 最佳 C 对应的平均交叉验证准确率\n",
    "\n",
    "    说明:\n",
    "        逻辑回归的 C 参数是正则化强度的倒数。\n",
    "        较小的 C 值会产生更强的正则化，可能防止过拟合。\n",
    "    \"\"\"\n",
    "    best_C = None\n",
    "    best_score = -np.inf\n",
    "    # 创建 K 折交叉验证分割器\n",
    "    kf = KFold(n_splits=n_splits, shuffle=True, random_state=RANDOM_STATE)\n",
    "\n",
    "    # 遍历所有候选的 C 值\n",
    "    for C in C_values:\n",
    "        fold_scores = []\n",
    "        # 对每一折进行训练和验证\n",
    "        for train_idx, val_idx in kf.split(X):\n",
    "            X_tr, X_val = X[train_idx], X[val_idx]\n",
    "            y_tr, y_val = y[train_idx], y[val_idx]\n",
    "\n",
    "            # 特征标准化：在训练集上拟合，然后转换训练集和验证集\n",
    "            scaler = StandardScaler()\n",
    "            X_tr_scaled = scaler.fit_transform(X_tr)\n",
    "            X_val_scaled = scaler.transform(X_val)\n",
    "\n",
    "            # 训练逻辑回归模型\n",
    "            clf = LogisticRegression(C=C, max_iter=1000, random_state=RANDOM_STATE)\n",
    "            clf.fit(X_tr_scaled, y_tr)\n",
    "            y_val_pred = clf.predict(X_val_scaled)\n",
    "            fold_scores.append(accuracy_score(y_val, y_val_pred))\n",
    "\n",
    "        # 计算当前 C 值的平均交叉验证得分\n",
    "        mean_score = np.mean(fold_scores)\n",
    "        print(f\"Logistic regression: C={C} mean CV accuracy={mean_score:.4f}\")\n",
    "\n",
    "        # 更新最佳参数\n",
    "        if mean_score > best_score:\n",
    "            best_score = mean_score\n",
    "            best_C = C\n",
    "\n",
    "    return best_C, best_score"
