    "def pairwise_distances_euclidean(X):\n",
    "    \"\"\"\n",
    "    计算 X 中所有行之间的成对欧几里得距离。\n",
    "\n",
    "    参数:\n",
    "        X: 形状为 (n_samples, n_features) 的数组\n",
    "\n",
    "    返回:\n",
    "        distances: 长度为 n_samples * (n_samples - 1) / 2 的一维数组，\n",
    "                   包含所有样本对之间的欧几里得距离\n",
    "\n",
    "    说明:\n",
    "        该函数计算上三角矩阵的距离（不包括对角线），避免重复计算。\n",
    "        时间复杂度为 O(n^2)，适用于中小规模数据集。\n",
    "    \"\"\"\n",
    "    n_samples = X.shape[0]\n",
    "    distances = []\n",
    "    # 遍历所有样本对 (i, j)，其中 i < j\n",
    "    for i in range(n_samples):\n",
    "        for j in range(i + 1, n_samples):\n",
    "            # 计算样本 i 和样本 j 之间的欧几里得距离\n",
    "            d = np.linalg.norm(X[i] - X[j])\n",
    "            distances.append(d)\n",
    "    return np.array(distances)\n"
   ],
