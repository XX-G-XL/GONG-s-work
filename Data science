    "        min(distances_subset1.min(), distances_subset2.min()),\n",
    "        max(distances_subset1.max(), distances_subset2.max()),\n",
    "        30,\n",
    "    )\n",
    "    plt.hist(\n",
    "        distances_subset1,\n",
    "        bins=bins,\n",
    "        alpha=0.5,\n",
    "        label=f\"Subset1 (class {label_for_subset})\",\n",
